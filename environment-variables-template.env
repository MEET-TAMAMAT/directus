# Directus Environment Variables Template
# Working configuration for Mailgun integration
# Date: 2026-05-16

# === EMAIL CONFIGURATION (MAILGUN) ===
EMAIL_FROM=admin@tamamat.com
EMAIL_TRANSPORT=mailgun
EMAIL_MAILGUN_API_KEY=your-mailgun-private-api-key-here
EMAIL_MAILGUN_DOMAIN=tamamat.com

# === SECURITY ===
SECRET=your-32-plus-character-random-secret-here

# === DATABASE (Railway PostgreSQL) ===
# These are automatically provided by Railway
# DB_CLIENT=pg
# DB_HOST=your-railway-postgres-host
# DB_PORT=5432
# DB_DATABASE=railway
# DB_USER=postgres
# DB_PASSWORD=your-railway-postgres-password

# === OPTIONAL CONFIGURATIONS ===
# CORS_ENABLED=true
# CORS_ORIGIN=true
# PUBLIC_URL=https://your-directus-url.up.railway.app

# === NOTES ===
# - Use EMAIL_MAILGUN_API_KEY (not EMAIL_MAILGUN_KEY)
# - Get Private API Key from Mailgun domain settings
# - SECRET must be 32+ characters for production
# - Verify domain in Mailgun before use